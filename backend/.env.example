# --- HTTP --------------------------------------------------------------------
PORT=4000
PUBLIC_BASE_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:3000

# --- Datastores --------------------------------------------------------------
MONGO_URI=mongodb://localhost:27017/vedaai
REDIS_URL=redis://localhost:6380

# --- LLM ---------------------------------------------------------------------
# provider = mock | openai | openrouter | gemini | anthropic
# When set to "mock" (default) no API key is required and a deterministic
# question paper is generated. The remaining adapters require their own keys.
LLM_PROVIDER=mock
LLM_MODEL=

OPENAI_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=VedaAI
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# --- Logging -----------------------------------------------------------------
LOG_LEVEL=info
NODE_ENV=development
